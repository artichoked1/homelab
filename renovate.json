{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "flux",
    "kubernetes",
    "custom.regex"
  ],
  "ignorePaths": [
    "**/gotk-components.yaml",
    "k8s/coma/apps/legacy/**"
  ],
  "flux": {
    "managerFilePatterns": [
      "/(^|/)k8s/.+\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)k8s/.+\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "For app-template releases, update app image tags but not the app-template chart version",
      "matchManagers": [
        "flux"
      ],
      "matchDatasources": [
        "helm"
      ],
      "matchPackageNames": [
        "app-template"
      ],
      "enabled": false
    },
    {
      "description": "Automerge patch updates",
      "matchUpdateTypes": ["patch"],
      "matchDatasources": ["docker"],
      "automergeType": "pr",
      "automerge": true
    }
  ]
}
